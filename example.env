# Database Configuration
# Select the database type: 'sqlite' or 'mysql'
DB_TYPE=sqlite

# SQLite Settings (Used if DB_TYPE is sqlite)
SQLITE_DB_PATH=snippets.db

# MySQL Settings (Used if DB_TYPE is mysql)
# Note: For Docker Compose, the host should match the db service name ('db')
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=snippet_vault
MYSQL_USER=mysql_user
MYSQL_PASSWORD=mysql_password
MYSQL_ROOT_PASSWORD=mysql_root_password
